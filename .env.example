# ── Binance API ──
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret


# ── Webhook (старый режим) ──
INVESTMENT_AMOUNT=5
LEVERAGE=20

# ── Strategy Engine ──
STRATEGY_ENABLED=true
STRATEGY_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,BNBUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,LINKUSDT,TRXUSDT,SUIUSDT,UNIUSDT,LTCUSDT,NEARUSDT,APTUSDT,ARBUSDT,OPUSDT,TIAUSDT,WIFUSDT,1000PEPEUSDT,FETUSDT,ATOMUSDT,INJUSDT,SEIUSDT,HBARUSDT,RENDERUSDT,GRTUSDT,AAVEUSDT,ICPUSDT,MKRUSDT,ALGOUSDT,VETUSDT,QNTUSDT,EGLDUSDT,SANDUSDT,GALAUSDT,MANAUSDT,AXSUSDT,FLOWUSDT,THETAUSDT,EOSUSDT,NEOUSDT,XLMUSDT,FILUSDT,STRKUSDT,ONDOUSDT,JUPUSDT,WLDUSDT,TAOUSDT
STRATEGY_TIMEFRAME=4h
STRATEGY_LEVERAGE=30
STRATEGY_KLINES_LIMIT=1500
MAX_CONCURRENT_POSITIONS=6

# ── Размер ставки ──
STRATEGY_USE_FIXED_AMOUNT=true
STRATEGY_FIXED_AMOUNT=5
RISK_PER_TRADE_PERCENT=1.0

# ── Nadaraya-Watson ──
NW_BANDWIDTH=8
NW_MULT=3
NW_LOOKBACK=500

# ── TP/SL (процент от инвестиции) ──
STRATEGY_TP_PERCENT=30
STRATEGY_SL_PERCENT=10
# true = LIMIT ордер (точная цена, без проскальзывания, maker fee)
# false = TAKE_PROFIT_MARKET (маркет при триггере, taker fee + slippage)
STRATEGY_TP_LIMIT_ORDER=true

# ── Сервер ──
HOST=0.0.0.0
PORT=8000
