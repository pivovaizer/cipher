# ── Binance API ──
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# ── Webhook (legacy mode) ──
INVESTMENT_AMOUNT=5
LEVERAGE=20

# ── Strategy Engine ──
STRATEGY_ENABLED=true
STRATEGY_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT
STRATEGY_TIMEFRAME=1h
STRATEGY_LEVERAGE=20
STRATEGY_KLINES_LIMIT=550
MAX_CONCURRENT_POSITIONS=4

# ── Position Sizing ──
STRATEGY_USE_FIXED_AMOUNT=true
STRATEGY_FIXED_AMOUNT=5
RISK_PER_TRADE_PERCENT=1.0

# ── Nadaraya-Watson Indicator ──
NW_BANDWIDTH=8
NW_MULT=3
NW_LOOKBACK=500

# ── Take Profit / Stop Loss (% from investment) ──
STRATEGY_TP_PERCENT=20
STRATEGY_SL_PERCENT=10

# ── Server ──
HOST=0.0.0.0
PORT=8000
